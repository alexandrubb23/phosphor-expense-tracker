# Environment variables for the backend server
PORT=3000
FRONTEND_URL=http://localhost:5173

# Database connection string for PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/expense-tracker?schema=public"

# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="your-secret-at-least-32-characters-long"
BETTER_AUTH_URL="http://localhost:3000"

# Seed script — admin user credentials (only needed when running `bun run seed`)
# Generate a strong password: openssl rand -base64 18
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="REPLACE_WITH_STRONG_PASSWORD_MIN_16_CHARS"
