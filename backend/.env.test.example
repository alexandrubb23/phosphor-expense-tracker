# Environment variables for the backend server (test environment)
# Copy this file to .env.test and fill in values matching your local setup.
NODE_ENV=test
PORT=3000
FRONTEND_URL=http://localhost:5173

# Test database — must be a separate database from development
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/expense-tracker-test?schema=public"

# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="your-secret-at-least-32-characters-long"
BETTER_AUTH_URL="http://localhost:3000"

# Seeded admin user (used by global-setup to seed the test database)
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="REPLACE_WITH_STRONG_PASSWORD_MIN_16_CHARS"

# Seeded regular (non-admin) test user (used by global-setup to seed the test database)
TEST_USER_EMAIL="user@example.com"
TEST_USER_PASSWORD="REPLACE_WITH_STRONG_PASSWORD_MIN_16_CHARS"

# Disable AI extraction in tests to avoid hitting OpenAI
DISABLE_AI=true

# Webhook secret — required so the secret-validation e2e tests work correctly
WEBHOOK_SECRET="kaC++c9angAvay7cecWMm5Q9eYIMDHmvY1v+le8sr+Y="
